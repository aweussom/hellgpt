# HellGPT Discord Bot
# Copy to .env and fill in values

# Discord bot token (create at https://discord.com/developers)
# Requires: MESSAGE_CONTENT intent, GUILD_MEMBERS intent
HELLGPT_DISCORD_TOKEN="your-discord-bot-token-here"

# Ollama Cloud API key (same as critique bot)
OLLAMA_API_KEY="your-ollama-api-key-here"
